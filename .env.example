# Copy this file to .env and fill in real values. .env is gitignored.
# Keys marked [secret] must never leave your machine.
# Keys marked [public] are safe to share (e.g. the Langfuse public key).

# --- Twilio ---
# Trial tier sufficient post-pivot — agent dials user's SMS-verified personal
# cell, user roleplays IVR + rep on the other end. No second number required.
# [secret]
TWILIO_ACCOUNT_SID=
# [secret]
TWILIO_AUTH_TOKEN=
# Phone number the agent dials FROM (the trial-issued number).
TWILIO_AGENT_NUMBER=

# --- Outbound dial allowlist ---
# Comma-separated E.164 numbers. The dialer refuses any number not in this list.
# Non-negotiable safety fence. Set to the user's personal cell (E.164).
ALLOWED_DESTINATIONS=

# --- Deepgram (ASR) ---
# [secret]
DEEPGRAM_API_KEY=

# --- ElevenLabs (TTS) ---
# Free tier OK for development. Default voice = "Sarah" (EXAVITQu4vr4xnSDxMaL);
# override ELEVENLABS_VOICE_ID to pick a different stock or cloned voice.
# [secret]
ELEVENLABS_API_KEY=
# [public]
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Groq (IVR LLM with tool calling) ---
# Native strict JSON schema + tool use, sub-100ms TTFT on Groq's LPU.
# Model pin lives in `agent/llm_client.py` (IVR_MODEL).
# [secret]
GROQ_API_KEY=

# --- Anthropic (rep LLM, conversational structured output) ---
# Used in rep mode for natural conversation + RepTurnOutput extraction.
# Persona system prompt is prompt-cached. Model pin lives in
# `agent/llm_client.py` (REP_MODEL).
# [secret]
ANTHROPIC_API_KEY=

# --- Langfuse (observability, self-hosted) ---
# [public]
LANGFUSE_PUBLIC_KEY=
# [secret]
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
# Set to true to skip span recording even when keys are present. Useful
# when running without a local Langfuse backend — the OTel exporter
# otherwise spams `localhost:3000` connection-refused errors per call.
# LANGFUSE_DISABLED=true
