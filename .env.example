# Copy this file to .env and fill in real values. .env is gitignored.
# Keys marked [secret] must never leave your machine.
# Keys marked [public] are safe to share (e.g. the Langfuse public key).

# --- Twilio (agent account, upgraded off trial) ---
# [secret]
TWILIO_ACCOUNT_SID=
# [secret]
TWILIO_AUTH_TOKEN=
# Phone number the agent dials FROM (E.164, e.g. +15551234567).
TWILIO_AGENT_NUMBER=

# --- Twilio (mock payer account, trial is fine) ---
# Phone number the mock payer listens on. Agent dials TO this.
TWILIO_PAYER_NUMBER=

# --- Outbound dial allowlist ---
# Comma-separated E.164 numbers. The dialer refuses any number not in this list.
# Non-negotiable safety fence. During M1–M6 this should only contain your
# mock-payer number (and maybe your own cell for manual testing).
ALLOWED_DESTINATIONS=

# --- Deepgram (ASR) ---
# [secret]
DEEPGRAM_API_KEY=

# --- Cartesia (TTS) ---
# [secret]
CARTESIA_API_KEY=

# --- Groq (LLM: Qwen3-32B) ---
# [secret]
GROQ_API_KEY=

# --- Langfuse (observability, self-hosted, arrives at M4) ---
# [public]
LANGFUSE_PUBLIC_KEY=
# [secret]
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
