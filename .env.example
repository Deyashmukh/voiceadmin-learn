# Copy this file to .env and fill in real values. .env is gitignored.
# Keys marked [secret] must never leave your machine.
# Keys marked [public] are safe to share (e.g. the Langfuse public key).

# --- Twilio ---
# Single account. Trial through M4 (agent dials user's SMS-verified cell for
# manual role-play). Upgrade at M5 when the agent needs to dial an automated
# TwiML IVR that cannot press keys past the trial-message gate.
# [secret]
TWILIO_ACCOUNT_SID=
# [secret]
TWILIO_AUTH_TOKEN=
# Phone number the agent dials FROM. During M1–M4 this is the trial-issued
# number. At M5 it stays on the now-upgraded account (no change required).
TWILIO_AGENT_NUMBER=

# Phone number the mock payer listens on. Empty through M4. At M5 buy a
# second number on the upgraded account and put it here.
TWILIO_PAYER_NUMBER=

# --- Outbound dial allowlist ---
# Comma-separated E.164 numbers. The dialer refuses any number not in this list.
# Non-negotiable safety fence.
#   M1–M4: user's personal cell (E.164).
#   M5+:   add TWILIO_PAYER_NUMBER alongside the cell.
ALLOWED_DESTINATIONS=

# --- Deepgram (ASR) ---
# [secret]
DEEPGRAM_API_KEY=

# --- Cartesia (TTS) ---
# [secret]
CARTESIA_API_KEY=

# --- Groq (LLM) ---
# Single API key, two models:
#   - qwen/qwen3-32b                              clarification / IVR fallback reasoning
#   - meta-llama/llama-4-scout-17b-16e-instruct   Benefits extraction (strict JSON schema)
# [secret]
GROQ_API_KEY=

# --- Langfuse (observability, self-hosted, arrives at M4) ---
# [public]
LANGFUSE_PUBLIC_KEY=
# [secret]
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
